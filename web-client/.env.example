# Web Client Environment Configuration
# Copy this to .env and fill in your values

# API Server URL (supports ngrok, Docker, or prod servers)
# Leave empty for same-origin (development via Vite proxy)
# Examples:
#   EXPO_PUBLIC_API_URL=http://localhost:3000
#   EXPO_PUBLIC_API_URL=https://your-ngrok-tunnel.ngrok-free.dev
#   EXPO_PUBLIC_API_URL=https://api.example.com
EXPO_PUBLIC_API_URL=

# Vite-only override (takes precedence over EXPO_PUBLIC_API_URL for web-client only)
# VITE_API_URL=http://localhost:3000
