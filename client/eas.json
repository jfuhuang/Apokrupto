{
  "cli": {
    "version": ">= 18.0.6",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "env": {
        "EXPO_PUBLIC_API_URL": "https://apokrupto-server.onrender.com/",
        "EXPO_PUBLIC_API_PORT": "3000"
      }
    },
    "internal": {
      "distribution": "internal",
      "env": {
        "EXPO_PUBLIC_API_URL": "https://apokrupto-server.onrender.com/",
        "EXPO_PUBLIC_API_PORT": "3000"
      }
    },
    "preview": {
      "distribution": "internal",
      "env": {
        "EXPO_PUBLIC_API_URL": "https://apokrupto-server.onrender.com/",
        "EXPO_PUBLIC_API_PORT": "3000"
      }
    },
    "production": {
      "autoIncrement": true,
      "distribution": "internal",
      "env": {
        "EXPO_PUBLIC_API_URL": "https://apokrupto-server.onrender.com/",
        "EXPO_PUBLIC_API_PORT": "3000"
      }
    }
  },
  "submit": {
    "production": {}
  }
}